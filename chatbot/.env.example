# Server (0.0.0.0 = lắng nghe mọi interface; client gọi http://localhost:8090)
CHATBOT_HOST=0.0.0.0
CHATBOT_PORT=8090

# MySQL (cùng DB với emp.server — copy từ Connection details, không commit password thật)
DB_HOST=your_db_host
DB_PORT=25060
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# CORS — client + admin
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Bắt buộc cho AI (ưu tiên 1) ---
# Lấy key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.4
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_HISTORY_LIMIT=10

# JWT — phải GIỐNG emp.server (JWT_ACCESS_SECRET)
# Dev: có thể tắt auth để test nhanh (CHATBOT_REQUIRE_AUTH=false)
# Production: bật true
CHATBOT_REQUIRE_AUTH=false
JWT_ACCESS_SECRET=change-me-access

SHOP_URL=http://localhost:5173

# SQLite hội thoại (tự tạo khi chạy)
LOCAL_STORE_PATH=data/chatbot.db

# --- Production ---
# CHATBOT_REQUIRE_AUTH=true
# JWT_ACCESS_SECRET=<phải giống JWT_ACCESS_SECRET của emp.server>
# GEMINI_API_KEY=<key thật>
# Kiểm tra: python scripts/smoke_test.py
